              }
            ],
            "expression": "SUM(tab_fato[release_price])",
            "lineageTag": "13712aac-b05d-4ea3-87e0-9ba24856d990"
          },
          {
            "name": "Qtd Fabricantes",
            "expression": "DISTINCTCOUNT(tab_fato[Manufacturer_ID])",
            "formatString": "0",
            "lineageTag": "05235547-d30c-423c-b6d5-a9852ed00d8e"
          },
          {
            "name": "Memoria Media MB",
            "expression": "AVERAGE(tab_fato[Memory])",
            "formatString": "0",
            "lineageTag": "edc47d4d-81b1-46f6-934a-291e5e3220fa"
          },
          {
            "name": "Receita YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "TOTALYTD(SUM(tab_fato[release_price]), dim_calendario[Date])",
            "lineageTag": "35214525-134d-4ed2-ac45-5745490df972"
          },
          {
            "name": "Receita MTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "TOTALMTD(SUM(tab_fato[release_price]), dim_calendario[Date])",
            "lineageTag": "4ee13019-b6fb-488a-b5bc-1e2586b3e6c7"
          },
          {
            "name": "Lancamentos Ano Anterior",
            "expression": "CALCULATE(COUNTROWS(tab_fato), SAMEPERIODLASTYEAR(dim_calendario[Date]))",
            "formatString": "0",
            "lineageTag": "7d08557b-2370-42db-821a-15b5108b782a"
          },
          {
            "name": "Menor Preco Componente Equivalente",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "// Menor preço entre GPUs com mesmo tipo e mesma capacidade de memória,",
              "// usando ALLEXCEPT para manter o contexto de Memory_Type e Memory,",
              "// mas remover filtros de fabricante (permite comparar entre fornecedores)",
              "CALCULATE(",
              "    MIN(tab_fato[release_price]),",
              "    ALLEXCEPT(tab_fato, tab_fato[Memory_Type_ID], tab_fato[Memory])",
              ")"
            ],
            "lineageTag": "0048b6fb-0dfa-475a-b7bf-9bedcb088d1b"
          },
          {
            "name": "Preco Medio Periodo Recente",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "// Média de preço apenas para GPUs lançadas nos últimos 2 anos",
              "// em relação à data mais recente da base (período \"recente\")",
              "CALCULATE(",
              "    AVERAGE(tab_fato[release_price]),",
              "    FILTER(",
              "        ALL(dim_calendario),",
              "        dim_calendario[Date] > EDATE(MAX(tab_fato[release_date]), -24)",
              "    )",
              ")"
            ],
            "lineageTag": "51b5fa3b-9ac9-47f8-b224-f89b2ca5b340"
          },
          {
            "name": "Preco Medio Periodo Historico",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "// Média de preço para GPUs lançadas antes dos últimos 2 anos",
              "// (período \"histórico\", anterior ao recente)",
              "CALCULATE(",
              "    AVERAGE(tab_fato[release_price]),",
              "    FILTER(",
              "        ALL(dim_calendario),",
              "        dim_calendario[Date] <= EDATE(MAX(tab_fato[release_date]), -24)",
              "    )",
              ")"
            ],
            "lineageTag": "7e877d1c-c252-465a-9a18-e3cc59d77712"
          },
          {
            "name": "Variacao Percentual Preco",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "// Compara a média de preço do período recente vs histórico,",
              "// retornando a variação percentual (queda ou alta de preços ao longo do tempo)",
              "VAR PrecoRecente = [Preco Medio Periodo Recente]",
              "VAR PrecoHistorico = [Preco Medio Periodo Historico]",
              "RETURN",
              "    DIVIDE(PrecoRecente - PrecoHistorico, PrecoHistorico, BLANK())"
            ],
            "lineageTag": "871ebff6-6183-43c7-9271-fa44fd918843"
          }
        ],
        "partitions": [
          {
            "name": "Medidas",
            "mode": "import",
            "source": {
              "expression": "ROW(\"Coluna_Apagar\", 0)",
              "type": "calculated"
            }
          }
        ]
