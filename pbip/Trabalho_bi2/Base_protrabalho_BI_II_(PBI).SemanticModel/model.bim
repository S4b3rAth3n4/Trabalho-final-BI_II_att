        "partitions": [
          {
            "name": "dim_calendario",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "ADDCOLUMNS(",
                "    CALENDAR(MIN(tab_fato[release_date]), MAX(tab_fato[release_date])),",
                "    \"Ano\", YEAR([Date]),",
                "    \"Mes\", MONTH([Date]),",
                "    \"NomeMes\", FORMAT([Date], \"MMMM\"),",
                "    \"Trimestre\", \"Q\" & QUARTER([Date]),",
                "    \"AnoMes\", FORMAT([Date], \"YYYY-MM\")",
                ")"
              ],
              "type": "calculated"
            }
          }
