              }
            ],
            "expression": "AVERAGE(tab_fato[release_price])",
            "lineageTag": "abcb1148-c84e-4eff-8abb-bb7024bdeea8"
          },
          {
            "name": "Receita Total Estimada",
            "annotations": [
              {
                "name": "PBI_FormatHint",
